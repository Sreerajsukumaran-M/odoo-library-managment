<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="cron_student_homework_reminder" model="ir.cron">
        <field name="name">checkout Reminder</field>
        <field name="model_id" ref="library_management.model_library_checkout"/>
        <field name="state">code</field>
        <field name="code">model.send_checkout_reminder()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="nextcall" eval="(DateTime.now() + timedelta(days=1))"/>
    </record>
</odoo>
