<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_library" name="library_management" inherit_id="portal.portal_breadcrumbs" priority="30">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'library_management'" t-attf-class="breadcrumb-item #{'active ' if fleet else ''}">
                <a t-if="library_management" t-attf-href="/library_management?{{ keep_query() }}">library_management</a>
                <t t-else="">library_management</t>
            </li>
        </xpath>
    </template>
    <template id="portal_my_home_menu_contribution" name="library_management" inherit_id="portal.portal_my_home"
              customize_show="True" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_client_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Contributions</t>
                <t t-set="url" t-value="'/library_management'"/>
                <t t-set="text">my book contributions</t>
                <t t-set="placeholder_count" t-value="'portal_library'"/>
            </t>
        </div>
    </template>
    <template id="portal_my_home_contribution_views" name="contribution">
        <t t-call="portal.portal_layout">


            <t t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th class="text-left">books Name</th>
                    </tr>
                </thead>
                <t t-foreach="books" t-as="record">
                    <tr>
                        <td class='text-left'>
                            <a t-attf-href="/my/book/#{record.id}"><span t-field="record.name"/>
                            </a>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>
     <template id="book_detail" name="Book Detail">
    <t t-call="portal.portal_layout">
        <div class="card shadow-lg rounded-10 p-4">
            <div class="row mb-4">
                <div class="col-md-3 text-center">
                    <t t-if="book.image">
                        <img t-attf-src="data:image/png;base64,#{book.image}"
                             class="img-thumbnail" style="max-height:250px;"/>
                    </t>
                    <t t-else="">
                        <div class="img-thumbnail d-flex align-items-center justify-content-center" style="height:250px;">
                            <span class="text-muted">No Image</span>
                        </div>
                    </t>
                </div>
                <div class="col-md-9">
                    <h2 t-esc="book.name"/>
                    <table class="table table-sm table-borderless w-auto">
                        <tr>
                            <th class="pr-4">Author</th>
                            <td><t t-esc="book.book_author_id.name or 'none'"/></td>
                        </tr>
                        <tr>
                            <th>ISBN</th>
                            <td><t t-esc="book.isbn"/></td>
                        </tr>
                        <tr>
                            <th>Condition</th>
                            <td><t t-esc="book.book_condition"/></td>
                        </tr>
                    </table>
                </div>
            </div>

            <t t-if="book.book_image">
                <div class="pt-4">
                    <h4>Additional Images</h4>
                    <div class="row">
                        <t t-foreach="book.book_image" t-as="att">
                            <div class="col-md-3 text-center pb-4">
                                <img t-attf-src="data:image/png;base64,{{att.datas}}"
                                     class="border"
                                     style="padding: 0px; margin: 0px; height: 150px; width: 150px; object-fit: cover;"/>
                            </div>
                        </t>
                    </div>
                </div>
            </t>

            <div class="pt-4">
                <a href="/library_management" class="btn btn-primary col-md-3 text-center">
                    Back to contributions
                </a>
                 <a href="/" class="btn btn-secondary col-md-3 text-center">
                    Back to home
                </a>
            </div>
        </div>
    </t>
</template>

</odoo>
