<odoo>
    <record id="action_library_tag" model="ir.actions.act_window">
        <field name="name">tags</field>
        <field name="res_model">library.tags</field>
        <field name="view_mode">list</field>
    </record>
    <record id="view_property_tags_list" model="ir.ui.view">
        <field name="name">library.tags.list</field>
        <field name="model">library.tags</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>
</odoo>