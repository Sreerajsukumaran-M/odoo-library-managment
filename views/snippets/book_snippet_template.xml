<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <template id="book_snippet_template" name="Top selling books">
       <section class="categories_section">
           <div class="container">
               <div class="alert alert-info">
                   <h4>Top selling books
                   </h4>
               </div>
           </div>
       </section>
   </template>
   <template id="category_highlight_snippet" inherit_id="website.snippets"
             name="Top selling books">
       <xpath expr="//snippets[@id='snippet_groups']" position="inside" >
           <t t-snippet="library_management.book_snippet_template"/>
       </xpath>
       <xpath expr="//snippets[@id='snippet_structure']" position="inside">
           <t t-snippet="library_management.book_snippet_template"  t-thumbnail="/library_management/static/src/images/image1.png"/>
       </xpath>
   </template>
</odoo>
