<odoo>
    <record id="action_library_report_wizard" model="ir.actions.act_window">
        <field name="name">Book Borrow Report</field>
        <field name="res_model">library.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    <record id="library_report_wizard_view_form" model="ir.ui.view">
        <field name="name">library.report.wizard.form</field>
        <field name="model">library.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Book Borrow Report">
                <group string="Filters">
                    <group>
                        <field name="members_id"/>
                        <field name="book_id"/>
                        <field name="category_id"/>
                        <field name="genre_id"/>
                    </group>
                    <group>
                        <field name="checkout_date"/>
                        <field name="return_date"/>
                        <field name="sort"/>
                        <field name="sort_by"/>
                    </group>
                </group>
                <footer>
                    <button name="add_report_action"
                            string="print pdf"
                            type="object"
                            class="btn-primary"
                            icon="fa-print"/>
                     <button name="add_report_xlsx_action"
                            string="print xlsx"
                            type="object"
                            class="btn btn-danger text-nowrap"
                            icon="fa-print"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>





